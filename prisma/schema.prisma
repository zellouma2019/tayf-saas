generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

/// متجر (تاجر) — كل تاجر له متجر مستقل
model Shop {
  id             String       @id @default(cuid())
  /// معرّف فريد يُستخدم في الرابط مثل matbaa-alnoor
  slug           String       @unique
  /// اسم المتجر الظاهر للزبائن
  name           String
  /// كلمة مرور لوحة الإدارة
  adminPin       String
  /// بيانات الاتصال
  phone          String?
  whatsapp       String?
  email          String?
  address        String?
  /// رابط الشعار (اختياري) — base64 أو URL
  logoUrl        String?
  /// أيقونة الشعار الافتراضية (Printer, BookOpen, Scissors, ...)
  logoIcon       String      @default("Printer")
  /// اللون الرئيسي (اختياري) مثل #d4af37
  primaryColor   String?
  /// معرّف القالب اللوني (1-8)
  themeId        Int          @default(1)
  /// كود الدولة ISO (مثل: DZ, SA, AE)
  country        String      @default("DZ")
  /// لغة المتجر (ar, fr, en, tr, es)
  language       String      @default("ar")
  /// إعدادات مخصصة JSON: { services, pricing, delivery, general }
  settings       String?
  /// اسم صاحب المتجر
  ownerName      String?
  /// هاتف صاحب المتجر
  ownerPhone     String?
  /// هل المتجر نشط؟
  isActive       Boolean      @default(true)
  /// نوع الخطة: free أو paid
  plan           String      @default("free")
  /// الميزات المفعّلة JSON: { whatsappNotifications: true, ... }
  features       String?
  /// مدة التجربة بالأيام (null = بلا حدود)
  trialDays      Int?
  /// تاريخ بدء التجربة
  trialStartsAt  DateTime?
  /// ملاحظات المالك عن التاجر
  ownerNotes     String?
  /// معلومات الدفع
  paymentInfo    String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
  orders         PrintOrder[]
  shopSettings   Setting[]    @relation("ShopSettings")
  expenses       Expense[]
  customers      Customer[]
  auditLogs      AuditLog[]
  formTemplates  FormTemplate[]
  formRecords    FormRecord[]

  @@index([slug])
  @@index([isActive])
}

/// طلب طباعة
model PrintOrder {
  id                    String    @id @default(cuid())
  /// رقم المعاملة مثل A-1050
  reference             String    @unique
  /// نوع الخدمة: document, photo, binding, copy, card, poster
  serviceType           String
  serviceName           String
  /// اسم الملف
  fileName              String?
  fileType              String?
  fileSize              Int?
  /// بيانات الملف المرفوع (Base64)
  fileData              String?
  /// تحليل ذكي JSON
  smartAnalysis         String?
  /// خيارات الطباعة JSON
  options               String
  /// بيانات العميل JSON
  customer              String
  /// وقت التسليم JSON
  delivery              String
  /// الأسعار JSON
  pricing               String
  /// الوقت المتوقع للتسليم بالساعات
  estimatedHours        Int       @default(3)
  status                String    @default("pending")
  pages                 Int       @default(1)
  copies                Int       @default(1)
  total                 Int       @default(0)
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  readyAt               DateTime?
  deliveredAt           DateTime?
  /// تاريخ بدء الطباعة
  startedPrintingAt     DateTime?
  /// تاريخ انتهاء الطباعة
  completedPrintingAt   DateTime?
  /// تكلفة الإنتاج (لحساب الربح)
  cost                  Int       @default(0)
  /// وسوم مخصصة (JSON array of strings)
  tags                  String    @default("[]")
  /// ملاحظات إدارية
  adminNotes            String?
  /// ارتباط بالمتجر
  shopId                String?
  shop                  Shop?     @relation(fields: [shopId], references: [id])

  @@index([status])
  @@index([createdAt])
  @@index([shopId])
}

/// إعدادات النظام القابلة للتعديل من الإدارة
model Setting {
  id        String   @id @default(cuid())
  /// "services", "delivery", "general"
  key       String
  /// JSON
  value     String
  updatedAt DateTime @updatedAt
  /// ارتباط بالمتجر
  shopId    String?
  shop      Shop?    @relation("ShopSettings", fields: [shopId], references: [id])

  @@unique([shopId, key])
}

/// إعدادات المدير الأول - كلمة المرور وأعضاء الفريق
model SuperAdmin {
  id    String @id @default(cuid())
  /// مفتاح فريد - صف واحد فقط
  key   String @unique @default("main")
  /// كلمة مرور لوحة التحكم الرئيسية (مشفّرة ببسيط)
  password String @default("Admin@2025")
  /// قائمة أعضاء الفريق JSON: [{ email, name, role, addedAt }]
  teamMembers String @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/// مصاريف المتجر
model Expense {
  id          String   @id @default(cuid())
  shopId      String?
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  category    String
  amount      Int
  description String?
  date        DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
  @@index([category])
  @@index([date])
}

/// زبائن المتجر
model Customer {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  name      String
  phone     String
  email     String?
  address   String?
  notes     String?
  totalOrders Int     @default(0)
  totalSpent  Int     @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([shopId, phone])
  @@index([shopId])
  @@index([phone])
}

/// سجل التدقيق
model AuditLog {
  id        String   @id @default(cuid())
  shopId    String?
  shop      Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  orderId   String?
  action    String
  field     String?
  oldValue  String?
  newValue  String?
  details   String?
  userId    String?
  createdAt DateTime @default(now())

  @@index([shopId])
  @@index([orderId])
  @@index([createdAt])
}

/// قوالب النماذج الرسمية
model FormTemplate {
  id          String   @id @default(cuid())
  shopId      String?
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  title       String
  icon        String   @default("FileText")
  category    String   @default("general")
  fields      String
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  records     FormRecord[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
}

/// سجلات النماذج المعبأة
model FormRecord {
  id          String   @id @default(cuid())
  shopId      String?
  shop        Shop?    @relation(fields: [shopId], references: [id], onDelete: Cascade)
  templateId  String?
  template    FormTemplate? @relation(fields: [templateId], references: [id])
  title       String
  data        String
  status      String   @default("draft")
  priority    String   @default("normal")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([shopId])
  @@index([status])
}